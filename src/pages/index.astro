---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import HowWeWork from "../components/HowWeWork.astro";
import ServicesNew from "../components/ServicesNew.astro";
import TestimonialsNew from "../components/TestimonialsNew.astro";
import Founders from "../components/Founders.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import en from "../locales/en.json";
import es from "../locales/es.json";

const currentPath = Astro.url.pathname;
const locale = currentPath.startsWith("/en") ? "en" : "es";
const t = locale === "en" ? en : es;

// SEO metadata from locale files
const seoTitle = t.seo.home.title;
const seoDescription = t.seo.home.description;
const seoKeywords = t.seo.home.keywords;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  locale={locale}
  imageAlt={locale === "en" ? "THIRD Studio - Software Development & Digital Innovation" : "THIRD Studio - Desarrollo de Software e Innovación Digital"}
>
  {/* Organization Structured Data — primary SEO signal for brand identity */}
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness", "ProfessionalService"],
      "@id": "https://thirdstudio.tech/#organization",
      name: "THIRD Studio",
      alternateName: ["THIRD Dev Studio", "Third Studio"],
      url: "https://thirdstudio.tech",
      logo: {
        "@type": "ImageObject",
        url: "https://thirdstudio.tech/assets/img/logo.webp",
        width: 512,
        height: 512
      },
      image: "https://thirdstudio.tech/assets/img/logo.webp",
      description: seoDescription,
      foundingDate: "2023",
      foundingLocation: {
        "@type": "Place",
        name: "Guadalajara, Jalisco, México"
      },
      address: {
        "@type": "PostalAddress",
        addressLocality: "Guadalajara",
        addressRegion: "Jalisco",
        addressCountry: "MX"
      },
      areaServed: [
        { "@type": "Country", name: "Mexico" },
        { "@type": "Country", name: "United States" },
        { "@type": "AdministrativeArea", name: "Latin America" }
      ],
      sameAs: [
        "https://www.instagram.com/thirdstudio.tech",
        "https://www.linkedin.com/company/thirdstudio"
      ],
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer service",
        email: "hola@thirdstudio.tech",
        telephone: "+52-1-333-815-3789",
        availableLanguage: [
          { "@type": "Language", name: "Spanish" },
          { "@type": "Language", name: "English" }
        ]
      },
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: locale === "en" ? "Digital Services" : "Servicios Digitales",
        itemListElement: [
          { "@type": "Offer", itemOffered: { "@type": "Service", name: locale === "en" ? "Software Development" : "Desarrollo de Software" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: locale === "en" ? "AI Automation" : "Automatización con IA" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: locale === "en" ? "Web Development" : "Desarrollo Web" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: locale === "en" ? "Mobile Applications" : "Aplicaciones Móviles" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: locale === "en" ? "AR/VR Experiences" : "Experiencias AR/VR" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: locale === "en" ? "Strategic Consulting" : "Consultoría Estratégica" } },
          { "@type": "Offer", itemOffered: { "@type": "Service", name: locale === "en" ? "Digital Transformation" : "Transformación Digital" } }
        ]
      },
      knowsAbout: [
        "Software Development", "Artificial Intelligence", "Machine Learning",
        "Virtual Reality", "Augmented Reality", "Web Development",
        "Mobile Applications", "Digital Transformation", "Technology Consulting",
        "API Development", "Cloud Architecture", "Business Strategy"
      ]
    })}
  />
  <div class="site-wrapper">
    <Header locale={locale} />

    <main>
      <Hero locale={locale} />
      <HowWeWork locale={locale} />
      <ServicesNew locale={locale} />
      <TestimonialsNew locale={locale} />
      <Founders locale={locale} />
      <Contact locale={locale} />
    </main>

    <Footer locale={locale} />

    <BackToTop />
  </div>
</BaseLayout>

<style>
  .site-wrapper {
    background-color: #0a0a0a;
    min-height: 100vh;
  }
</style>
